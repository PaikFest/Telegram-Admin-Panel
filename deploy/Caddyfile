:80 {
  encode gzip zstd
  header {
    -Server
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    X-Frame-Options "DENY"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: blob:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'; form-action 'self'"
  }

  handle /health {
    respond "ok" 200
  }

  @api path {$ADMIN_BASE_PATH}/api {$ADMIN_BASE_PATH}/api/*
  handle @api {
    reverse_proxy backend:3001
  }

  @app path {$ADMIN_BASE_PATH} {$ADMIN_BASE_PATH}/*
  handle @app {
    reverse_proxy frontend:3000
  }

  handle {
    respond "not found" 404
  }
}
