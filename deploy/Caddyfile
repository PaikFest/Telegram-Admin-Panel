:80 {
  encode gzip zstd

  handle /health {
    respond "ok" 200
  }

  @api path {$ADMIN_BASE_PATH}/api {$ADMIN_BASE_PATH}/api/*
  handle @api {
    reverse_proxy backend:3001
  }

  @app path {$ADMIN_BASE_PATH} {$ADMIN_BASE_PATH}/*
  handle @app {
    reverse_proxy frontend:3000
  }

  handle {
    respond "not found" 404
  }
}
